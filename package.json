{
  "name": "my-3dverse-app",
  "description": "A 3dverse powered application",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "vite --host",
    "dev:mqtt": "vite --host --mode mqtt",
    "dev:bridge": "vite --host --mode bridge",
    "build": "tsc -b && vite build",
    "build:mqtt": "tsc -b && vite build --mode mqtt",
    "build:bridge": "tsc -b && vite build --mode bridge",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@3dverse/api": "^0.8.14",
    "@3dverse/livelink": "^0.8.61",
    "@3dverse/livelink-react": "^0.2.60",
    "@3dverse/livelink-react-ui": "^0.3.17",
    "@tailwindcss/vite": "^4.1.5",
    "mqtt": "^5.15.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "baseline-browser-mapping": "^2.9.19",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5"
  }
}
